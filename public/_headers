# Cloudflare Workers Static Assets honors this file (like Cloudflare Pages).
# Security headers (CSP, HSTS, etc.) are set at the zone level in the
# infrastructure repo's Cloudflare ruleset, NOT here. Keep those there.
#
# These rules add a modest cache TTL to the static assets only. index.html and
# other HTML keep Cloudflare's default revalidate behavior, so content edits go
# live immediately on deploy; only CSS/JS/images may lag up to an hour after a
# same-filename replacement.

/css/*
  Cache-Control: public, max-age=3600

/js/*
  Cache-Control: public, max-age=3600

/images/*
  Cache-Control: public, max-age=3600
